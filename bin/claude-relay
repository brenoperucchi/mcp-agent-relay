#!/usr/bin/env bash
# claude-relay — launch Claude Code with the relay channel enabled (hands-free "job done"
# wake, no tmux). Exports the relay env directly so behaviour does not depend on what the
# MCP registration injects. All arguments are forwarded to `claude`.
#
#   claude-relay                       # plugin install (default)
#   claude-relay --bare                # bare install: `claude mcp add agentrelay`
#   RELAY_AGENT=my-id claude-relay     # override the session identity
#
# Plugin install (default): requires `claude plugin install mcp-agent-relay`.
# Bare install (--bare):    requires `claude mcp add agentrelay node /path/to/server.mjs`.
#
# Needs Claude Code >= 2.1.80 + Anthropic auth.

export RELAY_AGENT="${RELAY_AGENT:-claude-main}"
export RELAY_WORKER_AUTOSPAWN="${RELAY_WORKER_AUTOSPAWN:-1}"
export RELAY_WORKER_AGENTS="${RELAY_WORKER_AGENTS:-codex,claude-opus,claude-fable}"

CHANNEL_FLAG="plugin:mcp-agent-relay@mcp-agent-relay"
PASSTHROUGH=()

for arg in "$@"; do
  if [[ "$arg" == "--bare" ]]; then
    CHANNEL_FLAG="server:agentrelay"
  else
    PASSTHROUGH+=("$arg")
  fi
done

exec claude --dangerously-load-development-channels "$CHANNEL_FLAG" "${PASSTHROUGH[@]}"
